@page "/slides/{id}"
@model PortfolioSite.Pages.Slides.DetailsModel
@{
    var slide = Model.Slide!;
}

@section Head {
    <meta property="og:image" content="@slide.PreviewImageUrl" />
}

<article class="space-y-8 py-8 md:py-12">
    <header class="space-y-3">
        <p class="text-sm text-slate-500 dark:text-slate-400">@slide.PublishedOn.ToString("yyyy-MM-dd")</p>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100 md:text-4xl">@slide.Title</h1>
        <p class="whitespace-pre-line text-slate-700 dark:text-slate-300">@slide.Description</p>
        <a class="inline-flex rounded-lg bg-sky-600 px-4 py-2 font-semibold text-white hover:bg-sky-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-500" href="@slide.SpeakerDeckUrl" target="_blank" rel="noreferrer noopener">SpeakerDeck で見る</a>
    </header>

    <section class="space-y-3" aria-labelledby="slide-preview">
        <h2 id="slide-preview" class="text-xl font-semibold">Preview</h2>
        <img class="w-full rounded-xl border border-slate-200 dark:border-slate-800" src="@slide.PreviewImageUrl" alt="@slide.Title のプレビュー画像" />
    </section>

    @if (slide.Tags.Length > 0)
    {
        <ul class="flex flex-wrap gap-2" aria-label="Tags">
            @foreach (var tag in slide.Tags)
            {
                <li class="rounded-full bg-slate-200 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200">@tag</li>
            }
        </ul>
    }
</article>
