@page "/slides"
@model PortfolioSite.Pages.Slides.IndexModel
@{
    ViewData["Title"] = "Slides | tsubakimoto_s Portfolio";
    ViewData["Description"] = "公開中の登壇スライド一覧です。";
}

<section class="space-y-6 py-8 md:py-12">
    <header class="space-y-2">
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Slides</h1>
        <p class="text-slate-700 dark:text-slate-300">SpeakerDeck で公開しているスライドです。</p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var slide in Model.Slides)
        {
            <article class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:shadow-md dark:border-slate-800 dark:bg-slate-900">
                <a class="block focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-500" href="/slides/@slide.Id">
                    <img class="h-44 w-full object-cover" src="@slide.PreviewImageUrl" alt="@slide.Title のサムネイル" loading="lazy" />
                    <div class="space-y-2 p-4">
                        <p class="text-xs text-slate-500 dark:text-slate-400">@slide.PublishedOn.ToString("yyyy-MM-dd")</p>
                        <h2 class="line-clamp-2 text-base font-semibold text-slate-900 dark:text-slate-100">@slide.Title</h2>
                        <p class="line-clamp-2 text-sm text-slate-600 dark:text-slate-300">@slide.Description</p>
                    </div>
                </a>
            </article>
        }
    </div>
</section>
